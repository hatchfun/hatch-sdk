{
  "name": "hatch-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for launching tokens and claiming fees on Hatch (Solana).",
  "license": "MIT",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./constants": {
      "types": "./src/constants/index.ts",
      "default": "./src/constants/index.ts"
    },
    "./fees": {
      "types": "./src/fees/index.ts",
      "default": "./src/fees/index.ts"
    },
    "./launch": {
      "types": "./src/launch/index.ts",
      "default": "./src/launch/index.ts"
    },
    "./meteora": {
      "types": "./src/meteora/index.ts",
      "default": "./src/meteora/index.ts"
    },
    "./pda": {
      "types": "./src/pda/index.ts",
      "default": "./src/pda/index.ts"
    },
    "./utils": {
      "types": "./src/utils/index.ts",
      "default": "./src/utils/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@meteora-ag/dlmm": "^1.9.4",
    "@solana/spl-token": "^0.4.1",
    "@solana/web3.js": "^1.91.7",
    "bn.js": "^5.2.2"
  },
  "devDependencies": {
    "@types/bn.js": "^5.2.0",
    "@types/node": "^20.12.7",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hatchfun/hatch-sdk.git"
  },
  "files": [
    "src/",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "solana",
    "hatch",
    "meteora",
    "dlmm",
    "token-launch",
    "agent"
  ]
}
